<launch>
  <!-- 完整比赛仿真：导航 + VLM + 状态机 + 安全监控 -->
  <arg name="map_name" default="competition_field"/>

  <!-- 1. 仿真环境 (map + robot + AMCL + move_base) -->
  <include file="$(find mission_manager)/launch/sim_navigation.launch">
    <arg name="map_name" value="$(arg map_name)"/>
  </include>

  <!-- 2. Mock VLM (从 competition_field.yaml 读取 vision→task 映射) -->
  <node pkg="mission_manager" type="mock_vlm.py" name="mock_vlm" output="screen">
    <param name="confidence" value="0.85"/>
  </node>

  <!-- 3. Mock TTS (仿真语音播报) -->
  <node pkg="mission_manager" type="mock_tts.py" name="mock_tts" output="screen">
    <param name="speech_rate" value="8.0"/>
    <param name="max_duration" value="3.0"/>
  </node>

  <!-- 4. 任务状态机 (仿真模式) -->
  <node pkg="mission_manager" type="mission_state_machine.py" name="mission_state_machine" output="screen">
    <param name="sim_mode" value="true"/>
  </node>

  <!-- 5. 安全监控 -->
  <node pkg="mission_manager" type="safety_monitor.py" name="safety_monitor" output="screen"/>

  <!-- 6. RViz 可视化 -->
  <node pkg="rviz" type="rviz" name="rviz"
        args="-d $(find robot_slam)/rviz/view_navigation.rviz"/>


</launch>
