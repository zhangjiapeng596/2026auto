<launch>
    <!-- 相机参数 (默认对齐 perception.yaml / robot.yaml) -->
    <arg name="video_device" default="/dev/v4l/by-id/usb-HD_USB_Camera_HD_USB_Camera-video-index0"/>
    <arg name="image_width"  default="640"/>
    <arg name="image_height" default="480"/>
    <arg name="camera_fps"   default="15"/>

    <!-- 1. USB 相机驱动: 发布 /usb_cam/image_raw (bgr8), 供 doubao.py 拍照 -->
    <node name="usb_cam_node" pkg="abot_vlm" type="usb_cam_node.py" output="screen">
        <param name="video_device" value="$(arg video_device)"/>
        <param name="image_width"  value="$(arg image_width)"/>
        <param name="image_height" value="$(arg image_height)"/>
        <param name="fps"          value="$(arg camera_fps)"/>
        <param name="frame_id"     value="usb_cam"/>
        <param name="topic"        value="/usb_cam/image_raw"/>
    </node>

    <!-- 2. VLM 识别 (bridge + worker 架构: bridge=py2.7 ROS, worker=py3.9 豆包 API) -->
    <node name="top_view_shot_node" pkg="abot_vlm" type="vlm_bridge.py" output="screen">
        <param name="im_flag" type="int" value="255" />
    </node>
</launch>
